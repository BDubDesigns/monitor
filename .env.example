# Server Monitor — environment variables
# Copy to .env and customize.

BIND=0.0.0.0
MONITOR_PORT=3099
INTERVAL=30000

# Discord integration (optional)
# DISCORD_WEBHOOK=https://discord.com/api/webhooks/...

# Alert thresholds (optional, defaults shown)
# ALERT_CPU=90
# ALERT_RAM=90
# ALERT_DISK=85
# ALERT_COOLDOWN=15
# ALERT_CONSECUTIVE=3
